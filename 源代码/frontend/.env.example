# 前端环境变量配置示例
# 复制此文件为 .env.local 或 .env，然后根据实际情况修改

# ============ 基础配置 ============

# 部署时的基础路径（GitHub Pages 部署时使用）
# 如果你的仓库名是 power-trading-console，设置为 /power-trading-console/
# 如果部署到根路径，设置为 /
VITE_BASE_URL=/power-trading-console/

# 后端 API 地址（Render 部署后会提供）
# 本地开发：留空或 http://127.0.0.1:8000
# Render 部署后：https://你的项目名.onrender.com
VITE_API_BASE=https://your-backend.onrender.com
