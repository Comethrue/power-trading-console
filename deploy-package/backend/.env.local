# ============================================
# 电力交易AI平台 - 本地部署环境变量
# ============================================

# 应用环境
APP_ENV=local

# 服务配置
APP_HOST=127.0.0.1
APP_PORT=8000

# 前端静态文件（相对于backend目录）
APP_MOUNT_FRONTEND_DIST=true

# 数据库路径
APP_DATABASE_PATH=./data/power_trading.db

# 认证配置
APP_AUTH_ENABLED=true
APP_AUTH_JWT_SECRET=local-dev-secret-key-change-in-production

# CORS配置（允许本地开发）
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
